<view class="container">
  <view class="title">注册账号</view>
  <view class="card">
    <input placeholder="姓名" value="{{name}}" bindinput="onName" />
    <input placeholder="生日（YYYYMMDD）" type="number" maxlength="8" value="{{birthDate}}" bindinput="onBirthDate" style="margin-top: 12px;" />
    <picker mode="selector" range="{{genderOptions}}" value="{{genderIndex}}" bindchange="onGenderChange">
      <view style="margin-top: 12px; padding: 10px 12px; border: 1px solid #ddd; border-radius: 6px;">
        性别：{{genderOptions[genderIndex]}}
      </view>
    </picker>
    <input placeholder="手机号" type="number" maxlength="11" value="{{phone}}" bindinput="onPhone" style="margin-top: 12px;" />
  </view>
  <button class="btn-primary" bindtap="submit" loading="{{submitLoading}}">提交注册</button>
</view>
