<view class="container">
  <view class="title">欢迎使用老人健康</view>
  <view class="card">
    <view>请输入手机号登录（已注册账号）。</view>
    <input placeholder="请输入11位手机号" type="number" maxlength="11" value="{{phone}}" bindinput="onPhoneInput" style="margin-top: 12px;" />
    <button class="btn-primary" style="margin-top: 12px;" bindtap="doLogin" loading="{{loading}}">
      登录
    </button>
  </view>
  <view class="card">
    <view>没有账号请先注册。</view>
    <button bindtap="goRegister">去注册</button>
  </view>
</view>
